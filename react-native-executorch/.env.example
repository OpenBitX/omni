# Points the RN client at the parent browser app's Next.js dev server, which
# hosts both the existing /api/tts/stream and the four new /api/* wrappers
# around the server actions (assess, describe, generate-line, converse).
#
#   - iOS simulator / Android emulator:  http://localhost:3000
#   - Physical device on the same LAN:   http://<your-machine-LAN-IP>:3000
#
# Find your LAN IP on macOS:  ipconfig getifaddr en0
EXPO_PUBLIC_API_BASE=http://localhost:3000
