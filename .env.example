# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
#
# Vite reads VITE_* variables at build/dev time. The frontend dev server runs
# on :3000 and proxies /api/* + /ws/* to the unified Python backend on :8000
# (see vite.config.ts). The WebSocket URL helper (lib/backend-url.ts) connects
# directly to VITE_BACKEND_URL, bypassing the proxy.
VITE_BACKEND_URL=https://localhost:8000

# ─── Backend (Python FastAPI on :8000) ───────────────────────────────────────
#
# All AI/ML API keys are consumed server-side by backend/src/omni_backend/
# services/*.py. Nothing is ever shipped to the browser.

# Zhipu GLM-5V-Turbo — assess + describe on tap.
# bigmodel.cn keys look like `<hex>.<secret>`; api.z.ai keys start with `sk-`.
ZHIPU_API_KEY=

# OpenAI — gpt-4o-mini for the bundled first-tap VLM + gpt-4o-mini-transcribe
# for server-side speech-to-text (all STT runs on the backend now; no
# browser-side Whisper / transformers.js model is shipped to the client).
# Override the STT model with OPENAI_STT_MODEL (e.g. whisper-1 or
# gpt-4o-transcribe) if you want to trade off latency vs accuracy.
OPENAI_API_KEY=
# OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Cartesia Sonic — primary TTS. Without it, audio is skipped (caption-only).
CARTESIA_API_KEY=
# Optional overrides:
# CARTESIA_MODEL_ID=sonic-3
# CARTESIA_VOICE_ID_EN=a0e99841-438c-4a64-b679-ae501e7d6091
# CARTESIA_VOICE_ID_ZH=0cd0cde2-3b93-42b5-bcb9-f214a591aa29

# Cerebras — fast hot-path replies (~200ms). Falls back to OpenAI without it.
CEREBRAS_API_KEY=

# Runware — comic image generation in gallery.
RUNWARE_API_KEY=

# ─── Optional overrides ──────────────────────────────────────────────────────

# Override GLM endpoint (auto-detected from key shape by default).
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ─── Backend-only (YOLO / server) ────────────────────────────────────────────
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
# YOLO_MODEL=yolo11s-seg.pt
# YOLO_IMGSZ=704
# TEST_MODE=0
