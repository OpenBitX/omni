# === Required for Tracker (/) ===

# Zhipu GLM-5V-Turbo — voice-line generation on tap. bigmodel.cn keys look
# like `<hex>.<secret>`; api.z.ai keys start with `sk-`. Either is auto-detected.
ZHIPU_API_KEY=

# OpenAI — gpt-4o-mini for the bundled first-tap VLM call and whisper STT
# fallback. Required for lines; the app runs caption-only without it.
OPENAI_API_KEY=

# Cartesia Sonic — the only TTS backend. Without it, audio is skipped
# and the app runs caption-only. Get a key at https://play.cartesia.ai/keys.
CARTESIA_API_KEY=
# Optional: override the model / default voices.
# CARTESIA_MODEL_ID=sonic-3
# CARTESIA_VOICE_ID_EN=a0e99841-438c-4a64-b679-ae501e7d6091
# CARTESIA_VOICE_ID_ZH=0cd0cde2-3b93-42b5-bcb9-f214a591aa29

# === Optional overrides ===

# Override the GLM endpoint. Default is auto-picked from ZHIPU_API_KEY shape.
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
