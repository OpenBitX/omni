# omni-backend environment variables
# Copy to backend/.env or repo_root/.env.local and fill in values.

# === Mirror (required for /mirror route) ===
# Zhipu GLM-5V-Turbo API key for base-image face-coordinate detection.
# bigmodel.cn keys look like `<hex>.<secret>`, api.z.ai keys start with `sk-`.
ZHIPU_API_KEY=

# === YOLO (optional overrides) ===
# Model weight filename relative to backend/models/ or absolute path.
# Default: yolo11s-seg.pt  (ladder: s → m → l → x, see backend/src/omni_backend/routers/yolo.py)
# YOLO_MODEL=yolo11s-seg.pt
# YOLO_IMGSZ=704

# === Server ===
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# === Test / CI ===
# TEST_MODE=1   # skip all model loading; stub predictors used
