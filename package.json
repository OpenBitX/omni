{
  "name": "omni",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 --experimental-https --experimental-https-key certificates/key.pem --experimental-https-cert certificates/cert.pem",
    "prebuild": "node scripts/setup-ort.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "server": "server/.venv/bin/python server/server.py",
    "server:v2": "server-v2/.venv/bin/python server-v2/server.py",
    "demo": "concurrently -k -n next,py -c cyan,magenta \"npm:dev\" \"npm:server\"",
    "postinstall": "node scripts/setup-ort.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.1.0",
    "geist": "^1.7.0",
    "mermaid": "^11.14.0",
    "next": "^15.1.6",
    "onnxruntime-web": "^1.24.3",
    "openai": "^6.34.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
