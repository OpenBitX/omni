{
  "name": "omni",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "kill:3000": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\kill.ps1 3000",
    "kill:8000": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\kill.ps1 8000",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "backend": "uv --directory backend run python scripts/start.py",
    "backend:models": "uv --directory backend run python scripts/download_models.py",
    "backend:test": "uv --directory backend run pytest",
    "demo": "pnpm -s kill:3000 && pnpm -s kill:8000 && concurrently -k -n vite,py -c cyan,magenta \"pnpm:dev\" \"pnpm:backend\""
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@vitejs/plugin-react": "^6.0.1",
    "geist": "^1.7.0",
    "i18next": "^26.0.8",
    "mermaid": "^11.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.14.1",
    "vite": "^8.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
